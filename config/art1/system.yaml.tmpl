# Minimal system.yaml for art1.
#
# Only purpose: enable Mission Control. Access Federation / JPD pairing
# endpoints (POST /access/api/v1/system/jpd/pair, /bind) are gated on
# this flag — without it the API returns 404 and federation can't be
# bootstrapped non-interactively.
#
# Per https://jfrog.com/help/r/artifactory-setup-access-federation-step-by-step/step-1-enable-mission-control
#
# All other AF config (database, node, security) still comes from
# JF_SHARED_DATABASE_* env vars in compose/art1.yml — they take effect
# even with this file present, since system.yaml is additive (set values
# override env; unset values pass through).
#
# This file is rendered by scripts/render-templates.sh (no ${...} subs
# here today, but kept as .tmpl for consistency with the other configs).
configVersion: 1

mc:
  enabled: true
