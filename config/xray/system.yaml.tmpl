## Xray — system.yaml (TEMPLATE)
## Rendered by scripts/render-templates.sh from .env values.
## Joins art1 via shared JOIN_KEY (must equal what's in art1's system.yaml).
configVersion: 1

shared:
  jfrogUrl: http://artifactory1:8082
  node:
    id: xray-node-1
    name: xray-node-1
    ip: xray
  database:
    type: postgresql
    driver: org.postgresql.Driver
    url: jdbc:postgresql://postgres-xray:5432/xraydb
    username: xray
    password: ${PG_XRAY_PASSWORD}
  security:
    joinKey: ${JOIN_KEY}
    masterKey: ${MASTER_KEY}

xray:
  rabbitMq:
    active: true
    url: amqp://rabbitmq-xray:5672
    user: ${XRAY_RABBITMQ_USER}
    password: ${XRAY_RABBITMQ_PASSWORD}
