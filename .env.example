# Copy to .env and fill in. .env is gitignored.
#
# Quick start:  ./arti-deployer init   ← generates secrets + creates .env for you
#
# All secret-shaped values below are intentionally EMPTY. Either run `init` to
# auto-fill them with random values, or set them yourself.

# ─── REQUIRED — Artifactory license(s) ───────────────────────────────────────
# Paste your Artifactory license OR set ARTIFACTORY_LICENSE_FILE to a file on
# disk (absolute path). _2 variants are used by Artifactory 2 when running the
# dual-instance topology. If you leave the _2 vars empty, art2 falls back to
# the art1 license — JFrog will log a license conflict in that case but the
# lab still functions for testing.
ARTIFACTORY_LICENSE=
ARTIFACTORY_LICENSE_FILE=
ARTIFACTORY_LICENSE_2=
ARTIFACTORY_LICENSE_FILE_2=

# ─── REQUIRED — Shared trust keys (auto-generated by `init`) ─────────────────
# Both must be 32-hex-character strings (16 bytes). All AF instances in the
# lab share these so they can form a Circle of Trust.
# Generate: openssl rand -hex 16
JOIN_KEY=
MASTER_KEY=

# ─── REQUIRED — Service-account passwords (auto-generated by `init`) ─────────
# These never leave the docker network, but should still be unique per lab.
PG_AF1_PASSWORD=
PG_AF2_PASSWORD=
LDAP_ADMIN_PASSWORD=
LDAP_USER_PASSWORD=

# ─── Optional — AF admin password (after first login) ────────────────────────
# The post-up configurator scripts assume `admin / password` (the default
# pre-first-login state). If you change the admin password via UI, set it
# here so subsequent `up` runs can re-authenticate.
AF_ADMIN_PASSWORD=password

# ─── Optional — extra trusted CA bundle (corp TLS-intercepting proxy) ────────
# Absolute path to a PEM file containing one or more CA certificates to
# import into each AF container's JVM cacerts. Set this only if you're
# behind a TLS-intercepting corp proxy (Zscaler, Netskope, Palo Alto
# Prisma, ...) and AF logs show "PKIX path building failed" when remote
# repos try to reach public registries (npmjs.org, pypi.org, ...).
#
# Leave empty on networks with no MITM proxy.
#
# How to extract your corp's root CA on macOS (one-off, per machine):
#   security find-certificate -a -c "Zscaler" -p \
#     /Library/Keychains/System.keychain > ~/corp-ca.pem
# Replace "Zscaler" with your proxy vendor's CN (Netskope, ZIA, etc.).
#
# The PEM bytes never enter git — only the path below is read. .env itself
# is gitignored.
EXTRA_TRUSTED_CA_BUNDLE=

# Space-separated list of 'host[:port]' entries the AF container should
# probe to capture the *actual* cert chain a MITM proxy presents to it,
# including corp-internal intermediates that aren't in your local keychain.
# Default port is 443. The leaf cert is skipped — only intermediates and
# the root are imported.
#
# Typical value for the lab if you're behind a corp TLS proxy:
#   EXTRA_CA_PROBE_HOSTS="registry.npmjs.org pypi.org files.pythonhosted.org"
#
# Leave empty (the default) on networks with no MITM proxy. Combine with
# EXTRA_TRUSTED_CA_BUNDLE if you also have a static PEM file.
EXTRA_CA_PROBE_HOSTS=


# ─── Versions ────────────────────────────────────────────────────────────────
AF_VERSION=7.146.13
POSTGRES_VERSION=15
NGINX_VERSION=1.27
OPENLDAP_VERSION=1.5.0

# ─── Ports (host-side; container-side is fixed) ──────────────────────────────
AF1_HTTP_PORT=8081
AF1_ROUTER_PORT=8082
AF2_HTTP_PORT=8181
AF2_ROUTER_PORT=8182
NGINX_HTTP_PORT=8080
NGINX_HTTPS_PORT=8443
LDAP_PORT=1389
LDAP_TLS_PORT=1636

# ─── Project / network ───────────────────────────────────────────────────────
COMPOSE_PROJECT_NAME=arti-deployer
