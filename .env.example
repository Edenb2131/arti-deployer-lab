# Copy to .env and fill in. .env is gitignored.

# ─── Required ────────────────────────────────────────────────────────────────
# Paste your Artifactory license (the full multi-line block, all on one line
# with \n separators OR use ARTIFACTORY_LICENSE_FILE below to point to a file).
ARTIFACTORY_LICENSE=

# Alternatively, point to a license file on disk (overrides ARTIFACTORY_LICENSE
# if set). Path must be absolute.
ARTIFACTORY_LICENSE_FILE=

# ─── Versions ────────────────────────────────────────────────────────────────
AF_VERSION=7.98.9
XRAY_VERSION=3.107.13
POSTGRES_VERSION=15
NGINX_VERSION=1.27
KEYCLOAK_VERSION=25.0
OPENLDAP_VERSION=1.5.0

# ─── Ports (host-side; container-side is fixed) ──────────────────────────────
AF1_HTTP_PORT=8081
AF1_ROUTER_PORT=8082
AF2_HTTP_PORT=8181
AF2_ROUTER_PORT=8182
NGINX_HTTP_PORT=8080
NGINX_HTTPS_PORT=8443
KEYCLOAK_PORT=8090
LDAP_PORT=1389
LDAP_TLS_PORT=1636
XRAY_PORT=8000

# ─── Dev-only credentials (NOT for production; visible to anyone on host) ────
PG_AF1_PASSWORD=art1_dev_password
PG_AF2_PASSWORD=art2_dev_password
PG_XRAY_PASSWORD=xray_dev_password
LDAP_ADMIN_PASSWORD=admin_dev_password
KEYCLOAK_ADMIN_PASSWORD=admin_dev_password

# ─── Project / network ───────────────────────────────────────────────────────
COMPOSE_PROJECT_NAME=arti-deployer
