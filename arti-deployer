#!/usr/bin/env bash
# arti-deployer — Docker-Compose lab launcher for Artifactory Support work.
#
# Usage:
#   ./arti-deployer init            bootstrap .env with fresh secrets (run once)
#   ./arti-deployer                 interactive wizard (same as `up`)
#   ./arti-deployer up              interactive wizard
#   ./arti-deployer up [flags]      non-interactive (skip wizard); flags:
#                                     --instances {1|2}
#                                     --nginx | --https   (--https implies --nginx)
#                                     --ldap
#                                     --yes  (don't prompt for confirmation)
#   ./arti-deployer down            stop everything (keeps volumes)
#   ./arti-deployer reset           stop + wipe volumes (destructive)
#   ./arti-deployer cleanup [--all] full wipe: containers/volumes/networks/
#                                   rendered configs/state. --all also wipes
#                                   .env and .licenses/ (fresh-clone state).
#   ./arti-deployer fed-repos       create one federated repo per common
#                                   package type (generic/docker/maven/npm/
#                                   pypi/helm/nuget/gradle/composer/go).
#                                   Runs automatically as part of `up`
#                                   for 2-instance topologies; this
#                                   subcommand is for re-runs / repair.
#                                   `--delete` to remove them. `list` to
#                                   check which exist.
#   ./arti-deployer status          show running services
#   ./arti-deployer logs [service]  tail logs

set -euo pipefail

# shellcheck source=scripts/lib.sh
source "$(cd "$(dirname "$0")" && pwd)/scripts/lib.sh"

cmd="${1:-up}"

# ─── wizard helpers ──────────────────────────────────────────────────────────
wizard_af_version() {
  log_step "Artifactory version"
  log_info "Current AF_VERSION in .env: ${AF_VERSION}"
  if gum confirm "Use this version?"; then
    return
  fi
  local new_ver
  new_ver=$(gum input --prompt "Artifactory version: " --value "${AF_VERSION}" --placeholder "e.g., 7.111.9")
  if [[ -n "${new_ver}" && "${new_ver}" != "${AF_VERSION}" ]]; then
    update_env_var "AF_VERSION" "${new_ver}"
    log_ok "Updated .env: AF_VERSION=${new_ver}"
  fi
}

# wizard_one_license <1|2>
wizard_one_license() {
  local n="$1"
  local var_lic var_file
  if [[ "${n}" == "1" ]]; then
    var_lic="ARTIFACTORY_LICENSE"; var_file="ARTIFACTORY_LICENSE_FILE"
  else
    var_lic="ARTIFACTORY_LICENSE_2"; var_file="ARTIFACTORY_LICENSE_FILE_2"
  fi
  local cur_lic="${!var_lic:-}"
  local cur_file="${!var_file:-}"

  local status="not set"
  if [[ -n "${cur_file}" ]]; then
    status="file: ${cur_file}"
  elif [[ -n "${cur_lic}" ]]; then
    status="inline (${#cur_lic} chars)"
  fi
  log_info "Artifactory #${n} license: ${status}"

  local pick
  if [[ "${status}" != "not set" ]]; then
    pick=$(gum choose --header "License for AF#${n}:" \
      "Keep current" \
      "Paste a new license" \
      "Point to a license file" \
      "Clear")
  else
    pick=$(gum choose --header "License for AF#${n} (no value in .env):" \
      "Paste a license now" \
      "Point to a license file" \
      "Skip (AF will fail to start)")
  fi

  case "${pick}" in
    "Keep current") return ;;
    "Paste"*)
      log_info "Editor opens. Paste license content, then Ctrl+D to save."
      local lic_content
      lic_content=$(gum write --placeholder "Paste license (multi-line OK). Ctrl+D to save, Esc to cancel." --width 90 --height 18)
      if [[ -z "${lic_content}" ]]; then
        log_warn "Empty input; leaving license #${n} unchanged."
        return
      fi
      local lic_dir="${ROOT_DIR}/.licenses"
      mkdir -p "${lic_dir}" && chmod 700 "${lic_dir}"
      local lic_path="${lic_dir}/license-${n}.lic"
      printf '%s' "${lic_content}" > "${lic_path}"
      chmod 600 "${lic_path}"
      update_env_var "${var_file}" "${lic_path}"
      update_env_var "${var_lic}"  ""
      log_ok "Saved license to ${lic_path} and pointed ${var_file} at it in .env."
      ;;
    "Point"*)
      local path
      path=$(gum input --prompt "Absolute path to license file: " --placeholder "/path/to/artifactory.lic")
      if [[ -n "${path}" ]]; then
        if [[ ! -f "${path}" ]]; then
          log_warn "File not found at ${path}; setting anyway, fix before 'up'."
        fi
        update_env_var "${var_file}" "${path}"
        update_env_var "${var_lic}"  ""
        log_ok "Updated .env: ${var_file}=${path}"
      fi
      ;;
    "Clear")
      update_env_var "${var_lic}"  ""
      update_env_var "${var_file}" ""
      log_warn "Cleared both ${var_lic} and ${var_file} in .env."
      ;;
    "Skip"*)
      log_warn "AF#${n} will fail without a license; continuing anyway."
      ;;
  esac
}

# ─── wizard ──────────────────────────────────────────────────────────────────
wizard() {
  log_step "arti-deployer wizard"

  # 1. Instance count
  local count_choice
  count_choice=$(gum choose --header "How many Artifactory instances?" \
    "1" \
    "2  (auto-configures CoT + Access Federation)")
  INSTANCE_COUNT="${count_choice%% *}"

  # 2. Configurations — separate yes/no per overlay (clearer than a multi-
  #    select where users sometimes press Enter without toggling first).
  USE_NGINX=0; USE_LDAP=0; USE_NGINX_HTTPS=0

  if gum confirm "Add NGINX reverse proxy?"; then
    USE_NGINX=1
    if gum confirm "Use HTTPS for NGINX? (self-signed cert)"; then
      USE_NGINX_HTTPS=1
    fi
  fi

  if gum confirm "Add LDAP server?"; then
    USE_LDAP=1
  fi

  # 4. Artifactory version
  wizard_af_version

  # 5. Licenses (one per instance)
  log_step "Artifactory license(s)"
  wizard_one_license 1
  if [[ "${INSTANCE_COUNT}" == "2" ]]; then
    wizard_one_license 2
  fi

  # Show summary + confirm
  echo
  gum style --border rounded --padding "0 2" --border-foreground 51 \
"Selection:
  Instances:      ${INSTANCE_COUNT}
  AF version:     ${AF_VERSION}
  NGINX:          $([[ "${USE_NGINX}" == "1" ]] && echo "yes ($([[ "${USE_NGINX_HTTPS}" == "1" ]] && echo "HTTPS" || echo "HTTP"))" || echo no)
  LDAP:           $([[ "${USE_LDAP}" == "1" ]] && echo yes || echo no)"
  echo

  gum confirm "Proceed with this configuration?" || { log_warn "Cancelled."; exit 0; }

  save_selection
}

# ─── init ────────────────────────────────────────────────────────────────────
cmd_init() {
  check_deps
  "${SCRIPTS_DIR}/init-env.sh"
}

# ─── cleanup ─────────────────────────────────────────────────────────────────
cmd_cleanup() {
  check_deps
  "${SCRIPTS_DIR}/cleanup.sh" "$@"
}

# ─── fed-repos ───────────────────────────────────────────────────────────────
cmd_fed_repos() {
  check_deps
  load_env
  "${SCRIPTS_DIR}/fed-repos.sh" "$@"
}

# ─── parse_up_flags ──────────────────────────────────────────────────────────
# Returns 0 if any flag was passed (non-interactive), 1 if no flags (wizard).
# Sets INSTANCE_COUNT / USE_* globals.
parse_up_flags() {
  INSTANCE_COUNT=1
  USE_NGINX=0; USE_NGINX_HTTPS=0
  USE_LDAP=0
  local saw_flag=0
  local skip_confirm=0
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --instances) INSTANCE_COUNT="$2"; saw_flag=1; shift 2 ;;
      --nginx)     USE_NGINX=1;                          saw_flag=1; shift ;;
      --https)     USE_NGINX=1; USE_NGINX_HTTPS=1;       saw_flag=1; shift ;;
      --ldap)      USE_LDAP=1;                           saw_flag=1; shift ;;
      --yes|-y)    skip_confirm=1;                       saw_flag=1; shift ;;
      *) log_err "Unknown flag: $1"; exit 1 ;;
    esac
  done
  CONFIRM_NEEDED=$((1 - skip_confirm))
  if [[ "${INSTANCE_COUNT}" != "1" && "${INSTANCE_COUNT}" != "2" ]]; then
    log_err "--instances must be 1 or 2 (got ${INSTANCE_COUNT})"
    exit 1
  fi
  NON_INTERACTIVE="${saw_flag}"   # global: 1 = non-interactive, 0 = wizard
}

# ─── up ──────────────────────────────────────────────────────────────────────
cmd_up() {
  check_deps
  load_env

  parse_up_flags "$@"
  if [[ "${NON_INTERACTIVE}" == "1" ]]; then
    log_step "Non-interactive: instances=${INSTANCE_COUNT} nginx=${USE_NGINX} https=${USE_NGINX_HTTPS} ldap=${USE_LDAP}"
    save_selection
  else
    wizard
  fi

  log_step "Rendering config templates from .env"
  "${SCRIPTS_DIR}/render-templates.sh"

  log_step "Preparing license files"
  write_license art1
  [[ "${INSTANCE_COUNT}" == "2" ]] && write_license art2

  if [[ "${USE_NGINX_HTTPS}" == "1" ]]; then
    log_step "Generating self-signed cert for NGINX"
    "${SCRIPTS_DIR}/gen-self-signed.sh"
  fi

  log_step "Starting containers"
  # shellcheck disable=SC2046
  docker compose $(build_compose_chain) up -d

  log_step "Waiting for Artifactory health (first boot)"
  wait_for_af "${AF1_HTTP_PORT}" "Artifactory 1"
  if [[ "${INSTANCE_COUNT}" == "2" ]]; then
    wait_for_af "${AF2_HTTP_PORT}" "Artifactory 2"
  fi

  # Optional: import an extra CA bundle into the AF JVMs. No-op unless
  # EXTRA_TRUSTED_CA_BUNDLE is set in .env. Runs BEFORE the MC restart
  # below so that restart doubles as the cacerts-reload — no extra
  # downtime.
  "${SCRIPTS_DIR}/install-extra-cas.sh" \
    || log_warn "install-extra-cas.sh returned non-zero — proceeding anyway"

  # Restart Artifactory so Mission Control activates. mc.enabled in
  # system.yaml + JF_MC_ENABLED env var are read at startup, but on the
  # very first boot AF is still bootstrapping its data volume — the
  # internal service registry that hosts the mc microservice + the
  # Topology UI page needs the restart to register MC as a healthy peer.
  # After this restart, Administration → Topology shows registered JPDs.
  log_step "Restarting Artifactory to activate Mission Control"
  docker restart artifactory1 >/dev/null
  if [[ "${INSTANCE_COUNT}" == "2" ]]; then
    docker restart artifactory2 >/dev/null
  fi
  log_info "Waiting for Artifactory health (post-MC-restart, ~3-4 min)..."
  wait_for_af "${AF1_HTTP_PORT}" "Artifactory 1"
  if [[ "${INSTANCE_COUNT}" == "2" ]]; then
    wait_for_af "${AF2_HTTP_PORT}" "Artifactory 2"
  fi

  # Post-up configurators
  if [[ "${INSTANCE_COUNT}" == "2" ]]; then
    log_step "Configuring Circle of Trust + Access Federation"
    if "${SCRIPTS_DIR}/configure-cot.sh"; then
      log_step "Pre-creating federated repos (one per common package type)"
      "${SCRIPTS_DIR}/fed-repos.sh" create || log_warn "fed-repos returned non-zero — see scripts/fed-repos.sh"
    else
      log_warn "CoT configurator failed — skipping fed-repos (base URLs aren't set,"
      log_warn "so federated-repo creation would 500). Re-run with:"
      log_warn "  rm ${STATE_DIR}/.cot-configured 2>/dev/null"
      log_warn "  ./scripts/configure-cot.sh && ./arti-deployer fed-repos"
    fi
  fi

  if [[ "${USE_LDAP}" == "1" ]]; then
    log_step "Wiring LDAP into Artifactory"
    "${SCRIPTS_DIR}/configure-ldap.sh" || log_warn "LDAP configurator returned non-zero — see scripts/configure-ldap.sh"
  fi

  print_summary
}

# ─── down ────────────────────────────────────────────────────────────────────
cmd_down() {
  check_deps
  load_env
  load_selection
  # shellcheck disable=SC2046
  docker compose $(build_compose_chain) down
  log_ok "Stopped. Volumes preserved. Use 'reset' to wipe."
}

# ─── reset ───────────────────────────────────────────────────────────────────
cmd_reset() {
  check_deps
  load_env
  load_selection
  gum confirm "This will WIPE all volumes (Postgres + Artifactory data). Continue?" || exit 0
  # shellcheck disable=SC2046
  docker compose $(build_compose_chain) down -v
  rm -f "${STATE_DIR}"/.*-configured 2>/dev/null || true
  log_ok "Reset done."
}

# ─── status ──────────────────────────────────────────────────────────────────
cmd_status() {
  check_deps
  load_env
  load_selection
  # shellcheck disable=SC2046
  docker compose $(build_compose_chain) ps
}

# ─── logs ────────────────────────────────────────────────────────────────────
cmd_logs() {
  check_deps
  load_env
  load_selection
  local svc="${1:-}"
  # shellcheck disable=SC2046
  if [[ -n "${svc}" ]]; then
    docker compose $(build_compose_chain) logs -f "${svc}"
  else
    docker compose $(build_compose_chain) logs -f
  fi
}

case "${cmd}" in
  init)      cmd_init ;;
  up)        shift || true; cmd_up "$@" ;;
  down)      cmd_down ;;
  reset)     cmd_reset ;;
  cleanup)   shift || true; cmd_cleanup "$@" ;;
  fed-repos) shift || true; cmd_fed_repos "$@" ;;
  status)    cmd_status ;;
  logs)      shift || true; cmd_logs "${1:-}" ;;
  -h|--help|help)
    sed -n '2,19p' "$0" | sed 's/^# \{0,1\}//'
    ;;
  *)
    log_err "Unknown command: ${cmd}"
    exit 1
    ;;
esac
